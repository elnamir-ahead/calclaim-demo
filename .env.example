# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# Amazon Bedrock
BEDROCK_REGION=us-east-1
# Placeholder values (your-*, empty) are ignored — no Converse/ApplyGuardrail error locally
BEDROCK_GUARDRAIL_ID=your-guardrail-id
BEDROCK_GUARDRAIL_VERSION=DRAFT

# Amazon Bedrock AgentCore — invoke_agent requires 1–10 alphanumeric agentId & aliasId (AWS API).
# Placeholder text or empty agent → mock AgentCore response (no InvokeAgent call).
AGENTCORE_AGENT_ID=
AGENTCORE_AGENT_ALIAS_ID=TSTALIASID
USE_AGENTCORE=true

# LangSmith — use either LANGCHAIN_* (below) or LANGSMITH_* from the smith.langchain.com onboarding.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=calclaim-demo
# Optional aliases (same values as LangSmith “Configure environment”):
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=calclaim-demo
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_TRACING=true

# DynamoDB (state & audit)
DYNAMODB_CLAIMS_TABLE=calclaim-claims
DYNAMODB_AUDIT_TABLE=calclaim-audit-log
DYNAMODB_SESSION_TABLE=calclaim-sessions

# S3 (immutable audit archive)
S3_AUDIT_BUCKET=calclaim-audit-archive
S3_DATA_BUCKET=calclaim-data-lake

# Governance — OPA (policies/calclaim.rego). USE_OPA=true + OPA_SERVER_URL → HTTP policy; else inline engine.
OPA_SERVER_URL=http://localhost:8181
USE_OPA=false
HITL_SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:calclaim-hitl-review
PHI_DETECTION_CONFIDENCE_THRESHOLD=0.85

# App
ENVIRONMENT=demo
LOG_LEVEL=INFO
LOG_FORMAT=text
# LOG_FORMAT=json — structured JSON logs (correlation_id field when middleware runs)
DEMO_MODE=true

# API auth — local/ALB: validate JWT in FastAPI. API Gateway JWT authorizer: set TRUST_API_GATEWAY_AUTH=true and omit REQUIRE_AUTH.
# REQUIRE_AUTH=false
# TRUST_API_GATEWAY_AUTH=false
# JWT_JWKS_URL=https://cognito-idp.REGION.amazonaws.com/POOL_ID/.well-known/jwks.json
# JWT_AUDIENCE=your-app-client-id
# JWT_ISSUER=https://cognito-idp.REGION.amazonaws.com/POOL_ID

# CORS (FastAPI; Terraform/CDK also configure API Gateway CORS)
# CORS_ALLOW_ORIGINS=*

# MCP enterprise — host allowlist empty = any host (dev only). Prod: MCP_ALLOWED_HOSTS=mcp.yourvpc.internal
# MCP_ALLOWED_SCHEMES=https
# MCP_ALLOWED_HOSTS=
# MCP_BEARER_TOKEN=

# X-Ray — Lambda console “Active tracing” + optional pip install aws-xray-sdk (requirements-optional.txt)
# AWS_XRAY_TRACING_ENABLED=true
# XRAY_PATCH_SDK=true

# CloudWatch Embedded Metric Format (adjudication outcome metrics, no PHI in dimensions)
# ENABLE_CLOUDWATCH_EMF=true

# OpenTelemetry OTLP (optional; wire tracer in app code when adopting ADOT / multi-backend)
# OTEL_EXPORTER_OTLP_ENDPOINT=https://your-collector:4317
# OTEL_SERVICE_NAME=calclaim-api

# Optional: MCP tool server hints (not read by Lambda unless you wire it)
# CALCLAIM_API_BASE_URL=https://YOUR_API_ID.execute-api.us-east-1.amazonaws.com

# LangGraph → MCP (streamable HTTP): run mcp_servers with MCP_TRANSPORT=streamable-http, then:
# CALCLAIM_MCP_URL=http://127.0.0.1:8765/mcp
# USE_MCP_TOOLS=true
