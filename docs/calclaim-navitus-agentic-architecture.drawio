<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" modified="2026-04-01T00:00:00.000Z" agent="CalcClaim" version="24.7.0" type="device">
  <diagram id="navitus-calcclaim-demo" name="Navitus-style agentic adjudication demo">
    <mxGraphModel dx="1600" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="CalcClaim — Navitus-style agentic adjudication demo (repo-accurate, 2026)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=16;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="920" height="32" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="PRIMARY PATH (north → south) · Solid blue = request/response flow · Green dashed = MCP tools · Orange dashed = LangSmith · Grey dotted = metrics/logs" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=11;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="48" width="920" height="36" as="geometry" />
        </mxCell>

        <!-- PRIMARY COLUMN -->
        <mxCell id="gw" value="&lt;b&gt;Amazon API Gateway&lt;/b&gt;&lt;br&gt;HTTP API (v2) · Terraform path&lt;br&gt;Optional JWT authorizer (CDK/Terraform) or FastAPI JWT&lt;br&gt;CORS, throttling · &lt;i&gt;/claims/adjudicate&lt;/i&gt;, &lt;i&gt;/demo/ui/&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;spacingLeft=8;fontSize=11;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="80" y="100" width="280" height="100" as="geometry" />
        </mxCell>
        <mxCell id="lambda" value="&lt;b&gt;AWS Lambda + FastAPI&lt;/b&gt;&lt;br&gt;&lt;i&gt;Python 3.10+ recommended&lt;/i&gt; (3.12 in CDK examples; local venv may be 3.9)&lt;br&gt;Mangum ASGI · correlation ID middleware&lt;br&gt;Optional Bearer JWT · &lt;i&gt;boto3&lt;/i&gt; → Bedrock, DynamoDB, SNS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;spacingLeft=8;fontSize=11;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="80" y="220" width="280" height="110" as="geometry" />
        </mxCell>
        <mxCell id="graph" value="&lt;b&gt;LangGraph StateGraph&lt;/b&gt; (in-process in Lambda)&lt;br&gt;&lt;br&gt;&lt;b&gt;Governance&lt;/b&gt;: &lt;i&gt;pii_scrub&lt;/i&gt; → &lt;i&gt;phi_access_check&lt;/i&gt; → [DENY → &lt;i&gt;governance_deny&lt;/i&gt; → END]&lt;br&gt;&lt;br&gt;&lt;b&gt;Supervisor&lt;/b&gt; (&lt;i&gt;Claude 3 Haiku&lt;/i&gt;, Bedrock &lt;b&gt;Converse&lt;/b&gt;) — intent routing&lt;br&gt;&lt;br&gt;&lt;b&gt;Claims path&lt;/b&gt;:&lt;br&gt;  &lt;i&gt;agentcore_calcclaim&lt;/i&gt; (&lt;b&gt;InvokeAgent&lt;/b&gt; — mock if AGENTCORE ids invalid)&lt;br&gt;  → &lt;i&gt;mcp_tools&lt;/i&gt; (optional HTTP to MCP — &lt;i&gt;formulary_tier_lookup&lt;/i&gt;)&lt;br&gt;  → &lt;b&gt;calcClaim2 pipeline (7 nodes)&lt;/b&gt;: CostCore → Copay → MedicareD → Margin → DedCap → Special → Orchestrator (&lt;i&gt;validateResults&lt;/i&gt;)&lt;br&gt;  → &lt;i&gt;claims_agent&lt;/i&gt; (&lt;i&gt;Claude 3.5 Sonnet&lt;/i&gt;, Converse)&lt;br&gt;  · If Converse/model fails: optional &lt;b&gt;synthetic adjudication&lt;/b&gt; from &lt;i&gt;calc_claim2_context&lt;/i&gt; (&lt;i&gt;CALCLAIM_SYNTHETIC_*&lt;/i&gt; env)&lt;br&gt;&lt;br&gt;&lt;b&gt;Alternate paths&lt;/b&gt;: &lt;i&gt;formulary_agent&lt;/i&gt; (Haiku) · &lt;i&gt;compliance_agent&lt;/i&gt; (Sonnet) — no AgentCore/MCP/calcClaim2 chain&lt;br&gt;&lt;br&gt;&lt;b&gt;Quality gate&lt;/b&gt;: &lt;i&gt;policy_gate&lt;/i&gt; (OPA-style inline or OPA server) → &lt;i&gt;hitl_gate&lt;/i&gt; (SNS) → &lt;i&gt;guardrail_check&lt;/i&gt; (&lt;b&gt;ApplyGuardrail&lt;/b&gt; if ID set) → &lt;i&gt;audit&lt;/i&gt; → &lt;i&gt;response&lt;/i&gt;&lt;br&gt;&lt;br&gt;State: &lt;i&gt;correlation_id&lt;/i&gt;, &lt;i&gt;session_id&lt;/i&gt;, &lt;i&gt;calc_claim2_context&lt;/i&gt;, &lt;i&gt;mcp_tool_results&lt;/i&gt;, &lt;i&gt;agentcore_result&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;spacingLeft=10;fontSize=10;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="80" y="350" width="400" height="420" as="geometry" />
        </mxCell>
        <mxCell id="bedrock" value="&lt;b&gt;Amazon Bedrock&lt;/b&gt;&lt;br&gt;Models via &lt;b&gt;Converse&lt;/b&gt; (Sonnet / Haiku — use valid &lt;i&gt;modelId&lt;/i&gt; / inference profile per region)&lt;br&gt;Guardrails · AgentCore &lt;b&gt;InvokeAgent&lt;/b&gt;&lt;br&gt;Calls from Lambda (no VPC required for public endpoint; lock down with IAM)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#1a5276;align=left;spacingLeft=8;fontSize=11;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="80" y="790" width="400" height="100" as="geometry" />
        </mxCell>
        <mxCell id="persist" value="&lt;b&gt;Persistence + HITL&lt;/b&gt;&lt;br&gt;DynamoDB: claims, audit log, sessions (&lt;i&gt;DEMO_MODE&lt;/i&gt; → in-memory optional)&lt;br&gt;SNS: HITL topic · S3 Object Lock (WORM) via CDK stack&lt;br&gt;Audit events include &lt;i&gt;CALC_CLAIM2_STAGE&lt;/i&gt; per pipeline node" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;spacingLeft=8;fontSize=11;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="80" y="910" width="400" height="100" as="geometry" />
        </mxCell>
        <mxCell id="jsonout" value="&lt;b&gt;JSON response to client&lt;/b&gt;&lt;br&gt;&lt;i&gt;status&lt;/i&gt;, &lt;i&gt;pricing&lt;/i&gt; (copay, plan_pay), &lt;i&gt;workflow_steps&lt;/i&gt;, &lt;i&gt;correlation_id&lt;/i&gt;&lt;br&gt;&lt;i&gt;calc_claim2&lt;/i&gt; (full pipeline context), &lt;i&gt;agentcore_*&lt;/i&gt;, &lt;i&gt;mcp_tool_results&lt;/i&gt;&lt;br&gt;&lt;i&gt;audit_trail&lt;/i&gt;, &lt;i&gt;dur_alerts&lt;/i&gt;, &lt;i&gt;synthetic_from_calc_claim2&lt;/i&gt; when LLM fallback used" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;spacingLeft=8;fontSize=11;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="80" y="1030" width="400" height="110" as="geometry" />
        </mxCell>

        <!-- MCP -->
        <mxCell id="mcp" value="&lt;b&gt;MCP server&lt;/b&gt; (Model Context Protocol)&lt;br&gt;FastMCP — &lt;b&gt;separate&lt;/b&gt; from Lambda zip&lt;br&gt;ECS Fargate / internal ALB / streamable HTTP&lt;br&gt;Tool plane only; adjudication contract stays REST" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5f5e3;strokeColor=#27ae60;dashed=1;dashPattern=8 8;align=left;spacingLeft=8;fontSize=11;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="520" y="420" width="260" height="120" as="geometry" />
        </mxCell>

        <!-- Cross-cutting -->
        <mxCell id="cross" value="&lt;b&gt;CROSS-CUTTING&lt;/b&gt;" style="text;html=1;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="900" y="100" width="200" height="24" as="geometry" />
        </mxCell>
        <mxCell id="smith" value="&lt;b&gt;LangSmith&lt;/b&gt;&lt;br&gt;Tracing / eval (optional — &lt;i&gt;LANGCHAIN_API_KEY&lt;/i&gt;)&lt;br&gt;Does not replace CloudWatch" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff4e6;strokeColor=#e67e22;dashed=1;align=left;spacingLeft=8;fontSize=10;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="900" y="130" width="220" height="80" as="geometry" />
        </mxCell>
        <mxCell id="cw" value="&lt;b&gt;AWS observability&lt;/b&gt;&lt;br&gt;CloudWatch: Lambda logs, alarms, EMF (&lt;i&gt;ENABLE_CLOUDWATCH_EMF&lt;/i&gt;)&lt;br&gt;&lt;b&gt;IaC&lt;/b&gt;: Terraform (API, DDB, SNS) · CDK full stacks&lt;br&gt;GitHub Actions: &lt;i&gt;deploy-aws.yml&lt;/i&gt; — scan + deploy" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;align=left;spacingLeft=8;fontSize=10;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="900" y="230" width="240" height="120" as="geometry" />
        </mxCell>

        <!-- Pillars -->
        <mxCell id="pillarsTitle" value="&lt;b&gt;Three enterprise pillars (as implemented in demo)&lt;/b&gt;" style="text;html=1;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="1180" width="500" height="24" as="geometry" />
        </mxCell>
        <mxCell id="p1" value="&lt;b&gt;1. LLM Gateway&lt;/b&gt;&lt;br&gt;API Gateway → Lambda → Bedrock Converse · &lt;i&gt;ModelRouter&lt;/i&gt; (Haiku vs Sonnet)&lt;br&gt;Guardrails, AgentCore InvokeAgent, MCP tools" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ebf5fb;strokeColor=#3498db;align=left;spacingLeft=8;fontSize=10;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="80" y="1210" width="300" height="90" as="geometry" />
        </mxCell>
        <mxCell id="p2" value="&lt;b&gt;2. Evaluation&lt;/b&gt;&lt;br&gt;LangSmith traces · CloudWatch EMF · PDF-aligned pytest (&lt;i&gt;test_calc_claim2_components.py&lt;/i&gt;)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ebf5fb;strokeColor=#3498db;align=left;spacingLeft=8;fontSize=10;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="400" y="1210" width="300" height="90" as="geometry" />
        </mxCell>
        <mxCell id="p3" value="&lt;b&gt;3. Governance&lt;/b&gt;&lt;br&gt;JWT/IAM · PII scrub · Guardrails · OPA (&lt;i&gt;policies/calclaim.rego&lt;/i&gt;)&lt;br&gt;HITL (SNS) · immutable audit · calcClaim2 audit stages" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ebf5fb;strokeColor=#3498db;align=left;spacingLeft=8;fontSize=10;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="720" y="1210" width="300" height="90" as="geometry" />
        </mxCell>

        <mxCell id="note" value="&lt;b&gt;Optional (not in minimal demo zip)&lt;/b&gt;: S3 + Textract document ingestion · Open this file in &lt;a href=&quot;https://app.diagrams.net&quot;&gt;diagrams.net&lt;/a&gt; to edit." style="text;html=1;align=left;fontSize=10;fontColor=#7f8c8d;" vertex="1" parent="1">
          <mxGeometry x="80" y="1320" width="700" height="40" as="geometry" />
        </mxCell>

        <!-- Edges primary -->
        <mxCell id="e_gw_l" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#1a5276;strokeWidth=2;endArrow=classic;" edge="1" parent="1" source="gw" target="lambda">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_l_g" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#1a5276;strokeWidth=2;endArrow=classic;" edge="1" parent="1" source="lambda" target="graph">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_g_b" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#1a5276;strokeWidth=2;endArrow=classic;dashed=1;" edge="1" parent="1" source="graph" target="bedrock">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_b_p" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#1a5276;strokeWidth=2;endArrow=classic;" edge="1" parent="1" source="bedrock" target="persist">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_p_j" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#1a5276;strokeWidth=2;endArrow=classic;" edge="1" parent="1" source="persist" target="jsonout">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_mcp" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#27ae60;strokeWidth=1.5;endArrow=classic;dashed=1;" edge="1" parent="1" source="mcp" target="graph">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_smith" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#e67e22;endArrow=classic;dashed=1;" edge="1" parent="1" source="graph" target="smith">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_cw" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#999999;endArrow=open;dashed=1;dashPattern=1 4;" edge="1" parent="1" source="lambda" target="cw">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
